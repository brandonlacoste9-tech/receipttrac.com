generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String?           @db.VarChar(100)
  email             String            @unique @db.VarChar(255)
  password_hash     String?           @db.VarChar(255)
  telegram_id       String?           @unique @db.VarChar(100)
  created_at        DateTime?         @default(now()) @db.Timestamptz(6)
  region            String            @default("QUEBEC") @db.VarChar(50)
  authenticators    Authenticator[]
  receipts          Receipt[]
  vault_memberships VaultMembership[]

  @@map("users")
}

model Vault {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String            @db.VarChar(255)
  description String?
  created_at  DateTime          @default(now()) @db.Timestamptz(6)
  receipts    Receipt[]
  members     VaultMembership[]

  @@map("vaults")
}

model VaultMembership {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id  String @db.Uuid
  vault_id String @db.Uuid
  role     String @default("EXECUTIVE") @db.VarChar(50)
  user     User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  vault    Vault  @relation(fields: [vault_id], references: [id], onDelete: Cascade)

  @@unique([user_id, vault_id])
  @@map("vault_memberships")
}

model Authenticator {
  id                   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  credentialID         String  @unique
  credentialPublicKey  Bytes
  counter              BigInt
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user_id              String  @db.Uuid
  user                 User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("authenticators")
}

model Receipt {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String?   @db.Uuid
  store_name     String?   @db.VarChar(255)
  total_amount   Decimal?  @db.Decimal(10, 2)
  currency       String?   @default("CAD") @db.VarChar(10)
  items          Json?     @default("[]")
  image_url      String?
  scanned_at     DateTime? @default(now()) @db.Timestamptz(6)
  receipt_date   DateTime? @db.Date
  category       String?   @default("General") @db.VarChar(100)
  payment_method String?   @db.VarChar(50)
  notes          String?
  region         String?   @db.VarChar(50)
  subtotal       Decimal?  @db.Decimal(10, 2)
  tax_gst        Decimal?  @db.Decimal(10, 2)
  tax_hst        Decimal?  @db.Decimal(10, 2)
  tax_qst_pst    Decimal?  @db.Decimal(10, 2)
  tax_usa        Decimal?  @db.Decimal(10, 2)
  vault_id       String?   @db.Uuid
  user           User?     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  vault          Vault?    @relation(fields: [vault_id], references: [id], onDelete: Cascade)

  @@map("receipts")
}
